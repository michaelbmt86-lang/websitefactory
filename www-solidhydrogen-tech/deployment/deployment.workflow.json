{
  "workflow_name": "website_factory_runtime",
  "version": "4.0.0",

  "description": "Production-grade Website Factory Deployment Runtime. Monorepo mode — all websites stored in a single repository (michaelbmt86-lang/websitefactory). Each domain gets its own folder and Vercel project.",

  "continue_on_error": false,
  "fail_fast": true,

  "deploymentStrategy": {
    "mode": "monorepo",
    "monorepo": "michaelbmt86-lang/websitefactory",
    "alwaysCreateNewProject": false,
    "reuseExistingProject": true,
    "projectNameStrategy": "normalized-domain",
    "deleteOldProject": false,
    "verifyBeforeCleanup": true
  },

  "projectName": {
    "source": "normalized_domain",
    "example": {
      "input_url": "https://www.biopak.com",
      "domain": "biopak.com",
      "folder": "biopak-com",
      "vercel_project_name": "biopak-com"
    },
    "rules": [
      "Each website is stored inside the monorepo under a folder generated from the domain",
      "Folder name: domain with dots replaced by hyphens (e.g. websitefactorytest.online → websitefactorytest-online)",
      "Vercel project name: same as folder name",
      "One folder per domain — never duplicate, never overwrite other folders"
    ]
  },

  "steps": [
    {
      "step": 1,
      "id": "create_github",
      "action": "create_github",
      "provider": "github",
      "enabled": true,
      "required": true,
      "details": {
        "operation": "GET /repos/michaelbmt86-lang/websitefactory",
        "monorepo": "michaelbmt86-lang/websitefactory",
        "notes": "Verify the single monorepo exists. Create it only if it does not exist. Never create additional repositories."
      }
    },

    {
      "step": 2,
      "id": "push_code",
      "action": "push_code",
      "provider": "github",
      "enabled": true,
      "required": true,
      "details": {
        "operation": "POST /repos/michaelbmt86-lang/websitefactory/git/trees",
        "folder": "${projectFolder}",
        "branch": "main",
        "notes": "Push current project folder only. Never overwrite other project folders."
      }
    },

    {
      "step": 3,
      "id": "create_project",
      "action": "create_project",
      "provider": "vercel",
      "enabled": true,
      "required": true,
      "details": {
        "operation": "POST /v9/projects?teamId=glotalk",
        "name": "${projectSlug}",
        "rootDirectory": "${projectFolder}",
        "teamId": "glotalk",
        "framework": "nextjs",
        "notes": "Create ONE Vercel project per domain under the glotalk team. rootDirectory points to the domain folder in the monorepo."
      }
    },

    {
      "step": 4,
      "id": "connect_github",
      "action": "connect_github",
      "provider": "vercel",
      "enabled": true,
      "required": true,
      "details": {
        "operation": "POST /v9/projects/${projectId}/link",
        "type": "github",
        "repo": "michaelbmt86-lang/websitefactory",
        "productionBranch": "main",
        "rootDirectory": "${projectFolder}",
        "notes": "Link the monorepo to the Vercel project with rootDirectory set to the domain folder."
      }
    },

    {
      "step": 5,
      "id": "configure_env",
      "action": "configure_env",
      "provider": "vercel",
      "enabled": true,
      "required": true,
      "details": {
        "operation": "POST /v10/projects/${projectId}/env",
        "scope": "production",
        "variables": [
          "DATABASE_URL",
          "SESSION_SECRET",
          "ADMIN_USERNAME",
          "ADMIN_PASSWORD"
        ],
        "notes": "Set all required environment variables for production scope before deploying."
      }
    },

    {
      "step": 6,
      "id": "deploy_project",
      "action": "deploy_project",
      "provider": "vercel",
      "enabled": true,
      "required": true,
      "details": {
        "method": "vercel deploy --prod --yes",
        "token": "${VERCEL_TOKEN}",
        "expects": "readySubstate === PROMOTED",
        "timeout_seconds": 300,
        "notes": "Trigger production deployment. Must complete with READY state and PROMOTED substate."
      }
    },

    {
      "step": 7,
      "id": "bind_domain",
      "action": "bind_domain",
      "provider": "vercel",
      "enabled": true,
      "required": true,
      "details": {
        "operations": [
          "POST /v9/projects/${projectId}/domains — { name: ${domain} }",
          "POST /v9/projects/${projectId}/domains — { name: www.${domain} }"
        ],
        "domains": [
          "${domain}",
          "www.${domain}"
        ],
        "notes": "Bind both apex and www domains. Both must show verified: true."
      }
    },

    {
      "step": 8,
      "id": "configure_cloudflare_dns",
      "action": "configure_dns",
      "provider": "cloudflare",
      "enabled": true,
      "required": true,
      "details": {
        "zone_id": "${CLOUDFLARE_ZONE_ID}",
        "records": [
          {
            "name": "@",
            "type": "A",
            "content": "76.76.21.21",
            "proxied": true,
            "ttl": "auto"
          },
          {
            "name": "www",
            "type": "CNAME",
            "content": "cname.vercel-dns.com",
            "proxied": false,
            "ttl": "auto"
          }
        ],
        "notes": "Apex A record proxied through Cloudflare. www CNAME direct to Vercel (DNS-only)."
      }
    },

    {
      "step": 9,
      "id": "verify_dns",
      "action": "verify_dns",
      "provider": "system",
      "enabled": true,
      "required": true,
      "details": {
        "checks": [
          {
            "domain": "${domain}",
            "expect": "A record resolves to Cloudflare IPs"
          },
          {
            "domain": "www.${domain}",
            "expect": "CNAME resolves to cname.vercel-dns.com"
          }
        ],
        "retry": { "attempts": 5, "delay_seconds": 10 },
        "notes": "Confirm DNS records propagate before checking HTTPS."
      }
    },

    {
      "step": 10,
      "id": "verify_https",
      "action": "verify_https",
      "provider": "system",
      "enabled": true,
      "required": true,
      "details": {
        "urls": [
          "https://${domain}",
          "https://www.${domain}"
        ],
        "expect_status": 200,
        "expect_tls": true,
        "retry": { "attempts": 5, "delay_seconds": 10 },
        "notes": "Both domains must return a valid TLS certificate and HTTP 200."
      }
    },

    {
      "step": 11,
      "id": "verify_homepage",
      "action": "verify_homepage",
      "provider": "system",
      "enabled": true,
      "required": true,
      "details": {
        "url": "https://${domain}",
        "expect_status": 200,
        "expect_title_contains": "${site_title}",
        "min_content_bytes": 30000,
        "retry": { "attempts": 3, "delay_seconds": 5 },
        "notes": "Homepage must return 200, contain expected title, and be larger than 30 KB."
      }
    },

    {
      "step": 12,
      "id": "verify_dashboard_login",
      "action": "verify_dashboard_login",
      "provider": "browser",
      "enabled": true,
      "required": true,
      "details": {
        "url": "https://${domain}/login",
        "action": "submit login form",
        "credentials": {
          "username": "${ADMIN_USERNAME}",
          "password": "${ADMIN_PASSWORD}"
        },
        "expect_redirect_to": "/dashboard",
        "expect_status_after_login": 200,
        "retry": { "attempts": 3, "delay_seconds": 5 },
        "notes": "Navigate to /login, fill form, submit. Must redirect to /dashboard with HTTP 200."
      }
    },

    {
      "step": 13,
      "id": "verify_admin_account",
      "action": "verify_admin_account",
      "provider": "system",
      "enabled": true,
      "required": true,
      "details": {
        "api_url": "https://${domain}/api/auth/me",
        "method": "GET",
        "expect_status": 200,
        "expect_body_contains": "${ADMIN_USERNAME}",
        "retry": { "attempts": 3, "delay_seconds": 5 },
        "notes": "GET /api/auth/me must return the admin user object (not 401)."
      }
    },

    {
      "step": 14,
      "id": "delivery_complete",
      "action": "delivery_report",
      "provider": "delivery",
      "enabled": true,
      "required": true,
      "details": {
        "outputs": [
          "vercel_project_name",
          "vercel_project_id",
          "production_url",
          "custom_domain",
          "github_repo",
          "project_folder",
          "deployment_id",
          "dns_verified",
          "https_verified",
          "homepage_verified",
          "dashboard_verified",
          "admin_verified"
        ],
        "notes": "All steps passed. Site is live and admin is accessible."
      }
    }
  ]
}
