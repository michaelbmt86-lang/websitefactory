  },
  {
    "tag": "H2",
    "text": "Prof. \nFrancois Aguey-Zinsou",
    "classes": "font_2 wixui-rich-text__text"
  },
  {
    "tag": "SPAN",
    "text": "Prof.",
    "classes": "wixui-rich-text__text"
