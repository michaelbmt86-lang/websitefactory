  {
    "tag": "H1",
    "text": "SOLIDHYDROGEN hydrides solutions have the following benefits",
    "classes": "font_0 wixui-rich-text__text"
  },
  {
    "tag": "H5",
    "text": "OUR ADVANTAGE",
    "classes": "font_5 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Low cost – Cheapest storage of H2 per kg per cycle against any gaseous, liquid or solid storage",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Pure H2 with no\ntoxic or explosion\nrisk",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Long Life – 30 years+",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Fully recyclable",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Large energy density",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Long term storage\nand efficient at all temperatures",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Independent from\nrare and expensive raw materials",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Provides independence\nfor energy",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Low volume- 3 times as much energy per litre as H2 at 700 bar",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Quick cycles",
    "classes": "font_6 wixui-rich-text__text"
  },
  {
    "tag": "H6",
    "text": "Unparalleled\nflexibility in\nHydrogen use",
    "classes": "font_6 wixui-rich-text__text"
  },
