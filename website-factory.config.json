{
    "factory": {
      "name": "Website Factory",
      "version": "1.0.0",
      "mode": "production"
    },
  
    "project": {
      "root": "E:\\AI-Projects\\website-factory\\jcodemore"
    },
  
    "deployment": {
      "provider": "vercel",
      "github": true,
      "cloudflare": true,
      "useWrangler": false,
      "useCloudflareRestApi": true,

      "autoCreateProject": true,
      "reuseProject": false,
      "projectNameStrategy": "slug",
      "cleanupOldProject": false,
      "verifyAfterDeployment": true,
      "verifyDashboard": true,
      "verifyHttps": true,
      "verifyHomepage": true
    },
  
    "dashboard": {
      "enabled": true,
      "required": true
    },
  
    "database": {
      "provider": "sqlite"
    },
  
    "ai": {
      "provider": "gemini"
    },
  
    "crawler": {
      "provider": "firecrawl"
    }
  }